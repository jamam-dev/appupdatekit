<?xml version="1.0" encoding="utf-8"?>
<!--
    AppUpdateKit — activity_auk_force_update.xml
    Layout for the blocking force-update screen.
    All IDs are prefixed with "auk_fu_" to avoid host app resource conflicts.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/auk_fu_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Illustration / icon -->
        <ImageView
            android:id="@+id/auk_fu_illustration"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="32dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/auk_ic_update" />

        <!-- Title -->
        <TextView
            android:id="@+id/auk_fu_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Update Required"
            android:textColor="#1A1A2E"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Message from Remote Config -->
        <TextView
            android:id="@+id/auk_fu_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="A critical update is required to continue using this app."
            android:textColor="#555555"
            android:textSize="16sp" />

        <!-- Update button -->
        <Button
            android:id="@+id/auk_fu_btn_update"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1A73E8"
            android:text="Update Now"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>
</ScrollView>

