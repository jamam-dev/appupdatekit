<?xml version="1.0" encoding="utf-8"?>
<!--
    AppUpdateKit — activity_auk_maintenance.xml
    Layout for the blocking maintenance screen.
    All IDs are prefixed with "auk_mt_" to avoid host app resource conflicts.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/auk_mt_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Illustration / icon -->
        <ImageView
            android:id="@+id/auk_mt_illustration"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="32dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/auk_ic_maintenance" />

        <!-- Title -->
        <TextView
            android:id="@+id/auk_mt_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Under Maintenance"
            android:textColor="#1A1A2E"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Message from Remote Config -->
        <TextView
            android:id="@+id/auk_mt_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="We are currently under maintenance. Please check back soon."
            android:textColor="#555555"
            android:textSize="16sp" />

        <!-- Try Again button -->
        <Button
            android:id="@+id/auk_mt_btn_retry"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1A73E8"
            android:text="Try Again"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>
</ScrollView>

